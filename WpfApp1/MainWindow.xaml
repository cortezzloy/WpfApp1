<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор площади фигур" Height="406" Width="668"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Grid Margin="15,15,15,-26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <TextBlock Grid.Row="0" Text="Калькулятор площади фигур" 
                   FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,15"/>




        <StackPanel x:Name="RectanglePanel" Grid.Row="2" Margin="0,0,0,10">
            <Grid Height="116">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="1-я сторона:" Width="80" Margin="5"/>
                <TextBox x:Name="frstside" Grid.Row="0" Grid.Column="1" 
                         Width="150" HorizontalAlignment="Left" Margin="5" Text="0"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="2-я сторона:" Width="80" Margin="5"/>
                <TextBox x:Name="scndside" Grid.Row="1" Grid.Column="1" 
                         Width="150" HorizontalAlignment="Left" Margin="5,8,0,2" Text="0"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="3-я сторона:" Width="80" Margin="5,30,5,-23"/>
                <TextBox x:Name="thrdside" Grid.Row="1" Grid.Column="1" 
         Width="150" HorizontalAlignment="Left" Margin="5,33,0,-23" Text="0"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="радиус:" Width="80" Margin="5,54,5,-47"/>
                <TextBox x:Name="radius" Grid.Row="1" Grid.Column="1" 
Width="150" HorizontalAlignment="Left" Margin="5,56,0,-46" Text="0"/>

            </Grid>
        </StackPanel>

        <TextBlock Grid.Row="2" FontWeight="Bold" FontSize="14" Margin="403,1,143,84" Text="Вид фигуры:"/>

        <CheckBox x:Name="pryam" 
          Content="прямоугольник" 
          Checked="AcceptCheckBox_Checked"
          Unchecked="AcceptCheckBox_Unchecked"
          Margin="403,27,35,68" Grid.Row="2"/>

        <CheckBox x:Name="krug" 
  Content="круг" 
  Checked="AcceptCheckBox_Checked"
  Unchecked="AcceptCheckBox_Unchecked"
  Margin="403,47,35,48" Grid.Row="2"/>

        <CheckBox x:Name="treug" 
  Content="треугольник" 
  Checked="AcceptCheckBox_Checked"
  Unchecked="AcceptCheckBox_Unchecked"
  Margin="403,68,35,27" Grid.Row="2"/>
        <!-- Кнопка расчёта -->
        <Button x:Name="CalculateButton" Grid.Row="6" Content="Вычислить" 
                Click="CalculateButton_Click"
                Background="#2196F3" Foreground="White" FontSize="14" 
                Height="35"
                Margin="403,12,35,108" Cursor="Hand"/>

        <!-- Результат -->
        <Border Grid.Row="6" Background="#F0F0F0" Padding="10" Margin="10,10,358,95"
                BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Площадь:" FontWeight="Bold" FontSize="14"/>
                <TextBlock x:Name="ResultText" Grid.Row="1" FontSize="16" 
                           Foreground="#2196F3" FontWeight="Bold" Margin="0,5,0,0"
                           Text="—"/>
            </Grid>
        </Border>


    </Grid>
</Window>